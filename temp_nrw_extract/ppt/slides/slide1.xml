<p:sld xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:p="http://schemas.openxmlformats.org/presentationml/2006/main"><p:cSld><p:spTree><p:nvGrpSpPr><p:cNvPr id="1" name=""/><p:cNvGrpSpPr/><p:nvPr/></p:nvGrpSpPr><p:grpSpPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="0" cy="0"/><a:chOff x="0" y="0"/><a:chExt cx="0" cy="0"/></a:xfrm></p:grpSpPr><p:sp><p:nvSpPr><p:cNvPr id="2" name="TextBox 1"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="457200" y="274320"/><a:ext cx="8217762" cy="1077218"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="none"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr><a:defRPr sz="3200" b="1"/></a:pPr><a:r><a:rPr dirty="0"/><a:t>Impact of Reducing Non-Revenue Water (NRW)</a:t></a:r><a:endParaRPr lang="de-DE" dirty="0"/></a:p><a:p><a:pPr><a:defRPr sz="3200" b="1"/></a:pPr><a:r><a:rPr dirty="0"/><a:t>on Energy Costs</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="3" name="TextBox 2"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="457200" y="1371600"/><a:ext cx="8229600" cy="4572000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="none"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:endParaRPr/></a:p><a:p><a:pPr><a:defRPr sz="2000"/></a:pPr><a:r><a:t>Water utilities consume 0.4–0.8 kWh of energy per m³ of pumped water.</a:t></a:r></a:p><a:p><a:pPr><a:defRPr sz="2000"/></a:pPr><a:r><a:t>Every m³ of NRW saved reduces energy consumption proportionally.</a:t></a:r></a:p><a:p><a:pPr><a:defRPr sz="2000"/></a:pPr><a:r><a:t>NRW reduction lowers pumping hours, pressure demand, and treatment costs.</a:t></a:r></a:p><a:p><a:pPr><a:defRPr sz="2000"/></a:pPr><a:r><a:t>Energy represents 25–40% of total water utility operational costs.</a:t></a:r></a:p><a:p><a:pPr><a:defRPr sz="2000"/></a:pPr><a:r><a:t>Example: Reducing 50,000 m³/year saves ~27,500 kWh → ~4,100 €/year.</a:t></a:r></a:p></p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>